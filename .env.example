# ─────────────────────────────────────────────
#  Shopify Configuration
# ─────────────────────────────────────────────
# Your myshopify.com domain (no https://)
SHOPIFY_SHOP_URL=your-store.myshopify.com

# Private App or Custom App access token
# Admin → Settings → Apps → Develop apps → Create app
# Grant: read_analytics scope
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify Admin API version
SHOPIFY_API_VERSION=2024-10

# ─────────────────────────────────────────────
#  Google Search Console Configuration
# ─────────────────────────────────────────────
# The exact property URL as registered in GSC
GSC_SITE_URL=https://www.your-store.com

# Service Account JSON — paste the full JSON on a single line, or use a file path
# To create a service account:
#   1. Go to https://console.cloud.google.com
#   2. Create a project → Enable "Google Search Console API"
#   3. IAM & Admin → Service Accounts → Create → Download JSON key
#   4. In GSC → Settings → Users and permissions → Add user (service account email) with Full access
# Option A: inline JSON (recommended for Vercel)
GSC_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Option B: path to credentials file (local development only)
# GSC_CREDENTIALS_PATH=./credentials.json
